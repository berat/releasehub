{
  "name": "@releasehub/cli",
  "version": "1.0.0",
  "description": "AI-powered release notes from your terminal",
  "type": "module",
  "bin": {
    "releasehub": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^21.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "openai": "^6.41.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "release-notes",
    "changelog",
    "cli",
    "ai",
    "github"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/berat/releasehub"
  }
}
